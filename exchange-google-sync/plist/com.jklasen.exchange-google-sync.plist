<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.jklasen.exchange-google-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/REPLACE_ME/exchange-google-sync/venv/bin/python</string>
        <string>/Users/REPLACE_ME/exchange-google-sync/sync.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/REPLACE_ME/exchange-google-sync</string>

    <key>StartInterval</key>
    <integer>900</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/REPLACE_ME/Library/Logs/exchange-google-sync.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/REPLACE_ME/Library/Logs/exchange-google-sync.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
        <key>LANG</key>
        <string>de_DE.UTF-8</string>
    </dict>

    <key>ProcessType</key>
    <string>Background</string>

    <key>LowPriorityIO</key>
    <true/>
</dict>
</plist>
