---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';

export async function getStaticPaths() {
  const all = await getCollection('briefing');
  const deEntries = all.filter((e) => e.data.lang === 'de');
  const enSlugs = new Set(
    all
      .filter((e) => e.data.lang === 'en')
      .map((e) => e.id.replace(/^en\//, '').replace(/\.md$/, ''))
  );
  return deEntries.map((entry) => {
    const slug = entry.id.replace(/\.md$/, '');
    return {
      params: { slug },
      props: { entry, hasEnglishVersion: enSlugs.has(slug) },
    };
  });
}

const { entry, hasEnglishVersion } = Astro.props;
const { Content } = await render(entry);

const lang = 'de';
const t = useTranslations(lang);

const alternateLangPath = hasEnglishVersion
  ? `/en/briefing/${entry.id.replace(/\.md$/, '')}/`
  : undefined;

const formattedDate = entry.data.date.toLocaleDateString('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title={`${entry.data.title} | Jens Klasen`}
  description={entry.data.teaser}
  lang={lang}
  ogType="article"
  articleMeta={{
    publishedTime: entry.data.date.toISOString(),
    author: entry.data.author,
    section: 'Future Proof Tech Briefing',
  }}
  alternateLangPath={alternateLangPath}
>
  <article class="px-4 sm:px-6 lg:px-8" style="padding-top: 12rem; padding-bottom: 8rem;">
    <div class="max-w-2xl mx-auto">
      <!-- Header -->
      <header class="mb-16" data-animate>
        <p class="text-[11px] uppercase tracking-[0.3em] text-blood-400 font-display mb-6">
          {entry.data.kicker}
        </p>
        <h1
          class="text-4xl sm:text-5xl lg:text-6xl text-bone-100 leading-[1.05] mb-8"
          style="font-family: 'Metamorphous', 'Cinzel', Georgia, serif; font-weight: 400;"
        >
          {entry.data.title}
        </h1>
        <div class="flex items-center gap-4 text-[11px] uppercase tracking-[0.25em] text-bone-300/60 font-display">
          <time datetime={entry.data.date.toISOString()}>{formattedDate}</time>
          <span class="w-1 h-1 bg-bone-300/40 rounded-full"></span>
          <span>{t('briefing.article.readingTimeLabel')}: {entry.data.readingTime}</span>
        </div>
      </header>

      <!-- Body -->
      <div class="briefing-prose" data-animate>
        <Content />
      </div>

      <!-- Author -->
      <footer class="mt-20 pt-10 border-t border-bone-300/15" data-animate>
        <p class="text-[11px] uppercase tracking-[0.3em] text-blood-400 font-display mb-4">
          {t('briefing.article.author.heading')}
        </p>
        <p class="text-base text-bone-200/80 leading-relaxed mb-10">
          {t('briefing.article.author.body')}
        </p>
        <a
          href="/briefing/"
          class="inline-block text-xs uppercase tracking-[0.25em] font-display text-bone-300/70 hover:text-bone-50 transition-colors"
        >
          {t('briefing.article.back')}
        </a>
      </footer>
    </div>
  </article>
</Layout>

<style is:global>
  .briefing-prose {
    color: rgba(220, 209, 173, 0.85);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  .briefing-prose > * + * {
    margin-top: 1.5em;
  }

  .briefing-prose h2 {
    font-family: 'Metamorphous', 'Cinzel', Georgia, serif;
    font-weight: 400;
    font-size: 1.75rem;
    line-height: 1.25;
    color: rgb(245, 240, 224);
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    letter-spacing: 0;
    text-transform: none;
  }

  .briefing-prose h3 {
    font-family: 'Metamorphous', 'Cinzel', Georgia, serif;
    font-weight: 400;
    font-size: 1.375rem;
    line-height: 1.3;
    color: rgb(245, 240, 224);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: 0;
    text-transform: none;
  }

  .briefing-prose p {
    color: rgba(220, 209, 173, 0.85);
  }

  .briefing-prose strong {
    color: rgb(245, 240, 224);
    font-weight: 600;
  }

  .briefing-prose em {
    color: rgba(245, 240, 224, 0.95);
    font-style: italic;
  }

  .briefing-prose a {
    color: rgb(245, 240, 224);
    border-bottom: 1px solid rgba(139, 0, 0, 0.5);
    transition: color 0.2s, border-color 0.2s;
  }

  .briefing-prose a:hover {
    color: rgb(220, 38, 38);
    border-color: rgb(220, 38, 38);
  }

  .briefing-prose blockquote {
    border-left: 2px solid rgba(139, 0, 0, 0.6);
    padding-left: 1.5rem;
    margin-left: 0;
    font-style: italic;
    color: rgba(245, 240, 224, 0.9);
  }

  .briefing-prose ul,
  .briefing-prose ol {
    padding-left: 1.5rem;
  }

  .briefing-prose li {
    margin-top: 0.5em;
  }

  .briefing-prose hr {
    border: 0;
    border-top: 1px solid rgba(220, 209, 173, 0.15);
    margin: 3rem 0;
  }
</style>
