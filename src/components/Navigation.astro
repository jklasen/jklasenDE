---
import type { Lang } from '../i18n/utils';
import { getLocalizedPath, useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const otherLang = lang === 'de' ? 'en' : 'de';
const otherLangPath = lang === 'de' ? '/en/' : '/';

const homeBase = getLocalizedPath(lang, '/');
const briefingBase = lang === 'de' ? '/briefing/' : '/en/briefing/';

const navItems = [
  { href: `${homeBase}#home`, label: t('nav.home') },
  { href: `${homeBase}#about`, label: t('nav.about') },
  { href: `${homeBase}#career`, label: t('nav.career') },
  { href: `${homeBase}#certifications`, label: t('nav.certifications') },
  { href: briefingBase, label: t('nav.briefing') },
  { href: `${homeBase}#contact`, label: t('nav.contact') },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20 lg:h-24">
      <!-- Logo -->
      <a href={`${homeBase}#home`} class="flex items-center gap-3 group">
        <div class="relative w-14 h-14 lg:w-16 lg:h-16 flex-shrink-0 flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
          <img
            src="/images/jens-klasen-icon-gradient.png"
            alt="Jens Klasen — Sigil"
            class="w-full h-full object-contain"
            style="filter: drop-shadow(0 0 8px rgba(220,209,173,0.25));"
          />
        </div>
        <div class="hidden sm:flex flex-col leading-none">
          <span class="text-bone-100 text-xl uppercase tracking-[0.18em]" style="font-family: 'MedievalSharp', 'Cinzel', Georgia, serif;">
            Jens Klasen
          </span>
          <span class="text-[10px] uppercase tracking-[0.3em] text-blood-400 mt-1" style="font-family: 'MedievalSharp', 'Cinzel', Georgia, serif;">
            Technology Evangelist
          </span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="px-4 py-2 text-xs font-display font-bold uppercase tracking-[0.2em] text-bone-300 hover:text-bone-50 hover:bg-blood-700/20 border border-transparent hover:border-bone-300/20 transition-all"
          >
            {item.label}
          </a>
        ))}
      </div>

      <!-- Right side: Language -->
      <div class="flex items-center gap-2">
        <a
          href={otherLangPath}
          class="px-3 py-2 text-[11px] font-display font-bold uppercase tracking-[0.2em] text-bone-300 hover:text-bone-50 border border-bone-300/30 hover:border-bone-200/60 transition-all"
        >
          {otherLang === 'de' ? 'DE' : 'EN'}
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-toggle"
          class="lg:hidden p-2 text-bone-200 hover:text-bone-50 border border-bone-300/30"
          aria-label="Menu"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-forge-950/95 backdrop-blur-xl border-t border-bone-300/15">
    <div class="px-4 py-4 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block px-4 py-3 text-sm font-display font-bold uppercase tracking-[0.2em] text-bone-200 hover:text-bone-50 hover:bg-blood-700/20 border-l-2 border-transparent hover:border-blood-500 transition-all mobile-nav-link"
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 30) {
      navbar?.classList.add('bg-forge-950/85', 'backdrop-blur-xl', 'border-b', 'border-bone-300/10', 'shadow-2xl', 'shadow-black/50');
    } else {
      navbar?.classList.remove('bg-forge-950/85', 'backdrop-blur-xl', 'border-b', 'border-bone-300/10', 'shadow-2xl', 'shadow-black/50');
    }
  });

  // Mobile menu toggle
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>
