---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const passions = [
  {
    icon: '🦌',
    title: t('about.passions.animals'),
    desc: t('about.passions.animals.desc'),
    link: 'https://www.kitzrettungrheinhessen.de/',
    color: 'from-green-500 to-emerald-600',
  },
  {
    icon: '💪',
    title: t('about.passions.fitness'),
    desc: t('about.passions.fitness.desc'),
    color: 'from-orange-500 to-red-600',
  },
  {
    icon: '🎵',
    title: t('about.passions.music'),
    desc: t('about.passions.music.desc'),
    color: 'from-purple-500 to-violet-600',
  },
  {
    icon: '🏛️',
    title: t('about.passions.archaeology'),
    desc: t('about.passions.archaeology.desc'),
    color: 'from-amber-500 to-yellow-600',
  },
  {
    icon: '🔋',
    title: t('about.passions.tech'),
    desc: t('about.passions.tech.desc'),
    color: 'from-blue-500 to-cyan-600',
  },
];
---

<section id="about" class="section-padding bg-white dark:bg-gray-950">
  <div class="container-narrow">
    <!-- Section Header -->
    <div class="text-center mb-16" data-animate>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-gray-900 dark:text-white mb-4">
        {t('about.title')}
      </h2>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        {t('about.intro')}
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
      <!-- Personal Info -->
      <div class="space-y-8" data-animate>
        <div class="glass-card p-8">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
            <svg class="w-6 h-6 text-primary-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
            {t('about.personal.title')}
          </h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="mt-1 w-2 h-2 bg-primary-500 rounded-full flex-shrink-0"></span>
              <span class="text-gray-600 dark:text-gray-400">{t('about.personal.born')}</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-2 h-2 bg-primary-500 rounded-full flex-shrink-0"></span>
              <span class="text-gray-600 dark:text-gray-400">{t('about.personal.family')}</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-2 h-2 bg-primary-500 rounded-full flex-shrink-0"></span>
              <span class="text-gray-600 dark:text-gray-400 font-medium">{t('about.personal.values')}</span>
            </li>
          </ul>
        </div>

        <!-- Image -->
        <div class="rounded-2xl overflow-hidden shadow-xl">
          <img
            src="/images/31 - FotoLou-31.jpg"
            alt="Familie Klasen"
            class="w-full h-64 object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Passions -->
      <div class="space-y-4" data-animate>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
          <svg class="w-6 h-6 text-accent-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
          </svg>
          {t('about.passions.title')}
        </h3>
        {passions.map((passion) => (
          <div class="glass-card p-5 hover:scale-[1.02] transition-transform duration-200 group">
            <div class="flex items-start gap-4">
              <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${passion.color} flex items-center justify-center text-xl flex-shrink-0`}>
                {passion.icon}
              </div>
              <div>
                <h4 class="font-semibold text-gray-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                  {passion.link ? (
                    <a href={passion.link} target="_blank" rel="noopener noreferrer" class="hover:underline">
                      {passion.title} ↗
                    </a>
                  ) : passion.title}
                </h4>
                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{passion.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
