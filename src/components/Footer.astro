---
import type { Lang } from '../i18n/utils';
import { useTranslations, getLocalizedPath } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const impressumPath = getLocalizedPath(lang, '/impressum/');
---

<footer class="border-t border-bone-300/15 bg-forge-950/80 backdrop-blur-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <!-- Logo & Name -->
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 flex-shrink-0 rounded-full bg-bone-100 flex items-center justify-center overflow-hidden border border-bone-300/60"
             style="box-shadow: 0 0 0 1px rgba(0,0,0,0.4), 0 0 8px rgba(220,209,173,0.2);">
          <img
            src="/images/jens-icon-small.svg"
            alt="Jens Klasen Sigil"
            class="w-[86%] h-[86%] object-contain"
          />
        </div>
        <div>
          <p class="text-xl uppercase tracking-[0.18em] text-bone-100" style="font-family: 'MedievalSharp', 'Cinzel', Georgia, serif;">Jens Klasen</p>
          <p class="text-[10px] uppercase tracking-[0.3em] text-blood-400 mt-1" style="font-family: 'MedievalSharp', 'Cinzel', Georgia, serif;">Technology Evangelist</p>
        </div>
      </div>

      <!-- Social Links -->
      <div class="flex items-center gap-1 flex-wrap justify-center">
        <a href="https://www.linkedin.com/in/jensklasen/" target="_blank" rel="noopener noreferrer"
          class="p-2.5 text-bone-300/70 hover:text-bone-50 transition-colors" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href="https://x.com/jensklasen" target="_blank" rel="noopener noreferrer"
          class="p-2.5 text-bone-300/70 hover:text-bone-50 transition-colors" aria-label="X">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="https://www.instagram.com/klasenjens" target="_blank" rel="noopener noreferrer"
          class="p-2.5 text-bone-300/70 hover:text-bone-50 transition-colors" aria-label="Instagram">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </a>
        <a href="https://www.facebook.com/klasenjens" target="_blank" rel="noopener noreferrer"
          class="p-2.5 text-bone-300/70 hover:text-bone-50 transition-colors" aria-label="Facebook">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a href="https://t.me/jensklasen" target="_blank" rel="noopener noreferrer"
          class="p-2.5 text-bone-300/70 hover:text-bone-50 transition-colors" aria-label="Telegram">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
        </a>
        <a href="https://www.youtube.com/@JensKlasen-z7x" target="_blank" rel="noopener noreferrer"
          class="p-2.5 text-bone-300/70 hover:text-bone-50 transition-colors" aria-label="YouTube">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
        <a href="https://www.credly.com/users/jens-klasen" target="_blank" rel="noopener noreferrer"
          class="p-2.5 text-bone-300/70 hover:text-bone-50 transition-colors" aria-label="Credly">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.568 9.2l-6.2 6.2a1.5 1.5 0 01-2.12 0l-2.83-2.83a1.5 1.5 0 112.12-2.12l1.77 1.77 5.14-5.14a1.5 1.5 0 012.12 2.12z"/>
          </svg>
        </a>
      </div>

      <!-- Legal -->
      <div class="flex items-center gap-6 text-xs uppercase tracking-[0.2em] font-display text-bone-300/60">
        <a href={impressumPath} class="hover:text-bone-100 transition-colors">
          {t('footer.impressum')}
        </a>
        <span>© {new Date().getFullYear()} Jens Klasen</span>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-bone-300/10 text-center">
      <p class="font-rune text-xs text-bone-300/40 tracking-widest">
        ᚠᚢᚦᚨᚱᚲ · {lang === 'de' ? 'Im Feuer geschmiedet, im Code geschliffen' : 'Forged in fire, sharpened in code'} · ᚠᚢᚦᚨᚱᚲ
      </p>
    </div>
  </div>
</footer>
