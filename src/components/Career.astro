---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const timeline = [
  {
    year: '2025',
    rune: 'ᛉ',
    title: t('career.2025.title'),
    role: t('career.2025.role'),
    desc: t('career.2025.desc'),
    current: true,
  },
  {
    year: '2023',
    rune: 'ᛏ',
    title: t('career.2023.title'),
    role: t('career.2023.role'),
    desc: t('career.2023.desc'),
  },
  {
    year: '2011',
    rune: 'ᛟ',
    title: t('career.2011.title'),
    role: t('career.2011.role'),
    desc: t('career.2011.desc'),
  },
  {
    year: '2000',
    rune: 'ᚨ',
    title: t('career.2000.title'),
    role: t('career.2000.role'),
    desc: t('career.2000.desc'),
  },
];
---

<section id="career" class="section-padding relative">
  <div class="absolute inset-0 -z-0">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-blood-900/5 to-transparent"></div>
  </div>

  <div class="container-narrow relative">
    <!-- Section Header -->
    <div class="text-center mb-20" data-animate>
      <p class="eyebrow justify-center mb-6">
        <span>{lang === 'de' ? 'Die Chronik' : 'The Chronicle'}</span>
      </p>
      <h2 class="heading-carved text-5xl sm:text-6xl lg:text-7xl mb-6">
        {lang === 'de' ? 'Meine Saga' : 'My Saga'}
      </h2>
      <p class="text-lg text-bone-200/80">
        {lang === 'de' ? 'Vier Kapitel. Ein roter Faden: Technologie als Werkzeug — niemals als Selbstzweck.' : 'Four chapters. One thread: technology as a tool — never an end in itself.'}
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative" data-animate>
      <!-- Vertical spine -->
      <div class="absolute left-8 md:left-1/2 md:-translate-x-px top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-bone-300/30 to-transparent"></div>

      <div class="space-y-16">
        {timeline.map((item, i) => (
          <div class={`relative flex items-start gap-8 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
            <!-- Content Card -->
            <div class={`ml-20 md:ml-0 md:w-[calc(50%-3rem)] ${i % 2 === 0 ? 'md:pr-12 md:text-right' : 'md:pl-12'}`}>
              <div class={`forged-card p-7 transition-all duration-300 hover:-translate-y-1 hover:border-blood-500/40 ${item.current ? 'border-blood-500/50 shadow-blood' : ''}`}>
                {item.current && (
                  <div class={`flex items-center gap-2 mb-3 ${i % 2 === 0 ? 'md:justify-end' : ''}`}>
                    <span class="w-1.5 h-1.5 bg-blood-500 rounded-full animate-pulse"></span>
                    <span class="text-[10px] uppercase tracking-[0.3em] font-display text-blood-400">
                      {lang === 'de' ? 'Aktuell' : 'Current'}
                    </span>
                  </div>
                )}
                <div class="font-display text-3xl font-black text-blood-500 mb-2">
                  {item.year}
                </div>
                <h3 class="font-display uppercase tracking-wider text-lg text-bone-100 mb-1">
                  {item.title}
                </h3>
                <p class="text-xs uppercase tracking-[0.2em] text-bone-300/70 mb-4">
                  {item.role}
                </p>
                <p class="text-sm text-bone-200/80 leading-relaxed text-left">
                  {item.desc}
                </p>
              </div>
            </div>

            <!-- Timeline rune marker -->
            <div class="absolute left-0 md:left-1/2 md:-translate-x-1/2 w-16 h-16 bg-forge-950 border border-bone-300/30 flex items-center justify-center z-10">
              <span class="font-rune text-3xl text-blood-400">{item.rune}</span>
            </div>

            <!-- Spacer for alternating layout -->
            <div class="hidden md:block md:w-[calc(50%-3rem)]"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
