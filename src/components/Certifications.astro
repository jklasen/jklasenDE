---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const strategic = [
  'VMware Certified Professional — VMware Cloud Foundation 9 Administrator',
  'NVIDIA-Certified Associate: AI Infrastructure and Operations',
  'Broadcom Partner: Certified Expert — VMware Cloud Foundation',
  'Broadcom Partner: Proven Professional — VMware vSphere Foundation',
  'Broadcom Partner: Proven Professional — NSX',
  'AWS Partner: Sales Accreditation',
];

const community = [
  { name: 'VMUG Innovation in Leadership Award', year: '2024', highlight: true },
  { name: 'VMware vExpert PRO', year: '2026, 2025, 2024', highlight: true },
  { name: 'VMUG Volunteer Leader', year: '2026, 2025, 2024, 2023' },
  { name: 'VMware vExpert', year: '2017–2026 (10×)', highlight: true },
  { name: 'VMware vExpert vSAN', year: '2024, 2019, 2018, 2017' },
  { name: 'Dell EMC CTO Ambassador', year: '2017' },
];

const fundamental = [
  'VCP 9 / VCP-Cloud / VCP 5-DCV / VCP 4 / VCP 3',
  'VCAP4-DCA',
  'VCI: VMware Certified Instructor',
  'DCSA: DataCore Certified Solutions Architect',
  'ITIL Foundation',
  'MCSE (Windows 2000), MCSA (Windows 2003)',
  'MCTS (4×), MCP 2.0',
];
---

<section id="certifications" class="section-padding">
  <div class="container-narrow">
    <!-- Section Header -->
    <div class="text-center mb-20" data-animate>
      <p class="eyebrow justify-center mb-6">
        <span>{lang === 'de' ? 'Im Feuer geschmiedet' : 'Forged in fire'}</span>
      </p>
      <h2 class="heading-carved text-5xl sm:text-6xl lg:text-7xl mb-6">
        {lang === 'de' ? 'Schlachtnarben' : 'Battle Scars'}
      </h2>
      <p class="text-lg text-bone-200/80 max-w-2xl mx-auto">
        {lang === 'de' ? 'Zertifikate, Auszeichnungen und Community-Anerkennung — die sichtbaren Spuren von 25 Jahren an der Front.' : 'Certifications, awards, and community recognition — the visible traces of 25 years on the front line.'}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6" data-animate>
      <!-- Strategic -->
      <div class="forged-card p-8 group hover:border-blood-500/40 transition-colors">
        <div class="flex items-center gap-4 mb-6 pb-4 border-b border-bone-300/15">
          <span class="font-rune text-4xl text-blood-400">ᛗ</span>
          <h3 class="font-display uppercase tracking-wider text-base text-bone-100">
            {lang === 'de' ? 'Strategischer Fokus' : 'Strategic Focus'}
          </h3>
        </div>
        <ul class="space-y-3">
          {strategic.map((cert) => (
            <li class="flex items-start gap-3 text-sm text-bone-200/85">
              <span class="text-blood-500 mt-1 flex-shrink-0">▸</span>
              <span>{cert}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Community -->
      <div class="forged-card p-8 group hover:border-blood-500/40 transition-colors">
        <div class="flex items-center gap-4 mb-6 pb-4 border-b border-bone-300/15">
          <span class="font-rune text-4xl text-blood-400">ᚹ</span>
          <h3 class="font-display uppercase tracking-wider text-base text-bone-100">
            {lang === 'de' ? 'Anerkennung & Community' : 'Recognition & Community'}
          </h3>
        </div>
        <ul class="space-y-3">
          {community.map((item) => (
            <li class="flex items-start gap-3 text-sm">
              <span class={`mt-1 flex-shrink-0 ${item.highlight ? 'text-ember-400' : 'text-blood-500'}`}>
                {item.highlight ? '✦' : '▸'}
              </span>
              <div>
                <span class={`${item.highlight ? 'font-semibold text-bone-100' : 'text-bone-200/85'}`}>
                  {item.name}
                </span>
                <span class="block text-[10px] uppercase tracking-[0.2em] text-bone-300/50 mt-0.5">
                  {item.year}
                </span>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Fundamental -->
      <div class="forged-card p-8 group hover:border-blood-500/40 transition-colors">
        <div class="flex items-center gap-4 mb-6 pb-4 border-b border-bone-300/15">
          <span class="font-rune text-4xl text-blood-400">ᚱ</span>
          <h3 class="font-display uppercase tracking-wider text-base text-bone-100">
            {lang === 'de' ? 'Fundament' : 'Foundations'}
          </h3>
        </div>
        <ul class="space-y-3">
          {fundamental.map((cert) => (
            <li class="flex items-start gap-3 text-sm text-bone-200/85">
              <span class="text-blood-500 mt-1 flex-shrink-0">▸</span>
              <span>{cert}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Credly Link -->
    <div class="text-center mt-14" data-animate>
      <a
        href="https://www.credly.com/users/jens-klasen"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary"
      >
        {lang === 'de' ? 'Alle Schmiedezeichen auf Credly' : 'All marks on Credly'}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>
    </div>
  </div>
</section>
