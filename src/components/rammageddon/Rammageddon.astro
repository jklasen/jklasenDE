---
import type { Lang } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Route in die bestehende Briefing-Liste (aus Schritt 0 verifiziert).
const briefingBase = lang === 'de' ? '/briefing/' : '/en/briefing/';
// Deutsche Fassung dieser Seite (für den EN-Hinweis).
const germanPath = '/rammageddon/';
const stickerMuleUrl = 'https://www.stickermule.com/products/custom-stickers';

// Thesen-/Sektionsinhalte zweisprachig. Die EN-Fassung ist eine
// Übersetzung des deutschen Originals (Hinweis via rammageddon.langNotice).
const content = {
  de: {
    heroAlt: 'Verfallene, postapokalyptische Skyline von Frankfurt unter rostrotem Himmel',
    badgeAlt: 'RAMmageddon — Emblem',
    heroKicker: 'Marktthese',
    heroLine: 'Wer jetzt Hardware bestellt, zahlt den Preis von heute für die Architektur von gestern.',
    heroSub: 'Architektur-Strategie statt Hardware-Reflex.',
    marktEyebrow: 'Die Marktlage',
    marktTitle: 'Was die Zahlen sagen',
    stats: [
      { value: '+170 %', label: 'DRAM-Preis seit Q3/2025' },
      { value: '15–20 %', label: 'Server teurer (Listenpreise Enterprise-RAM)' },
      { value: '6 Monate', label: 'GPU-Wartezeit (Enterprise-Kontingente reserviert)' },
      { value: '70 %', label: 'der Chips gehen an Hyperscaler (Rest teilt sich der Mittelstand)' },
    ],
    driversLabel: 'Treiber',
    driversAria: 'Treiber der Krise',
    drivers: ['Section-232-Zölle', 'Iran-Konflikt', 'Exportkontrollen', 'kein Produktionsausbau'],
    reactEyebrow: 'Drei Reaktionen',
    reactTitle: 'Alle mit Risiko',
    riskLabel: 'Risiko',
    reactions: [
      { title: 'Panik-Bestellung', body: 'Hardware zu Höchstpreisen. Budget verbrannt, Architektur unverändert.', risk: 'Overpay' },
      { title: 'Abwarten & hoffen', body: 'Support verlängern, Problem verschieben. Keine strategische Antwort.', risk: 'Stillstand' },
      { title: 'Cloud-Flucht', body: 'Unkontrollierter Lift-and-Shift. Ineffizienzen wandern 1:1 in die OpEx.', risk: 'Lock-in' },
    ],
    quoteText: 'Die Zwangspause vom Hardware-Kauf ist keine verlorene Zeit — sie ist die seltene Gelegenheit, die IT-Strategie ohne Zeitdruck auf Vordermann zu bringen.',
    quoteFootPre: 'Wartezeit',
    quoteFootPost: 'Planungszeit',
    schlussEyebrow: 'Die strategische Schlussfolgerung',
    schlussTitle: 'Schlanker werden, bevor man kauft',
    steps: [
      { kicker: 'Software modernisieren', body: 'Cloud-native, Kubernetes — Workloads, die nicht mehr jede Hardware-Generation mitwachsen müssen.' },
      { kicker: 'Datenmodell modernisieren', body: 'Ein offenes Lakehouse statt gewachsener Silos — entkoppelt von proprietärer Infrastruktur.' },
    ],
    thesisLead: 'Die Zielarchitektur wird schlanker. Freigesetztes Hardware-Budget fließt in Modernisierung statt in die Hardware-Inflation. KI-ready Daten entstehen dabei als Beifang — nicht als eigenes Großprojekt, sondern als Nebeneffekt sauberer Architektur.',
    bandCockpitAlt: 'Blick aus einem verfallenen Fahrzeug auf gekippte Server-Racks in der Wüste vor der Frankfurter Skyline',
    bandInteriorAlt: 'Innenraum eines ausgeschlachteten Fahrzeugs voller alter Festplatten und Hardware-Schrott',
    bandKeyAlt: 'RAMmageddon — gekippte Server-Racks in einer Wüstenlandschaft vor der Frankfurter Skyline',
    stickerAlt: 'RAMmageddon — Emblem als Sticker-Vorlage',
    wallpapers: [
      { title: 'Key-Visual', preview: '/rammageddon/band-keyvisual.webp', file: '/rammageddon/downloads/rammageddon-wallpaper-keyvisual.jpg', res: '2814 × 1536', alt: 'RAMmageddon-Key-Visual: gekippte Server-Racks in der Wüste vor der Frankfurter Skyline' },
      { title: 'Frankfurt', preview: '/rammageddon/hero-wasteland-frankfurt.webp', file: '/rammageddon/downloads/rammageddon-wallpaper-frankfurt.jpg', res: '2816 × 1536', alt: 'Postapokalyptische Frankfurter Skyline unter rostrotem Himmel' },
      { title: 'Cockpit', preview: '/rammageddon/band-cockpit.webp', file: '/rammageddon/downloads/rammageddon-wallpaper-cockpit.jpg', res: '2814 × 1536', alt: 'Blick aus einem verfallenen Fahrzeug auf gekippte Server-Racks' },
      { title: 'Interieur', preview: '/rammageddon/band-interior.webp', file: '/rammageddon/downloads/rammageddon-wallpaper-interieur.jpg', res: '2752 × 1536', alt: 'Innenraum eines ausgeschlachteten Fahrzeugs voller Hardware-Schrott' },
    ],
  },
  en: {
    heroAlt: 'Derelict, post-apocalyptic Frankfurt skyline under a rust-red sky',
    badgeAlt: 'RAMmageddon — emblem',
    heroKicker: 'Market thesis',
    heroLine: "Buy hardware now and you pay today's prices for yesterday's architecture.",
    heroSub: 'Architecture strategy over hardware reflex.',
    marktEyebrow: 'State of the market',
    marktTitle: 'What the numbers say',
    stats: [
      { value: '+170 %', label: 'DRAM price since Q3 2025' },
      { value: '15–20 %', label: 'Servers cost more (enterprise-RAM list prices)' },
      { value: '6 months', label: 'GPU lead time (enterprise allocations spoken for)' },
      { value: '70 %', label: 'of chips go to hyperscalers (the mid-market splits the rest)' },
    ],
    driversLabel: 'Drivers',
    driversAria: 'Drivers of the crisis',
    drivers: ['Section 232 tariffs', 'Iran conflict', 'Export controls', 'no new capacity'],
    reactEyebrow: 'Three reactions',
    reactTitle: 'All carry risk',
    riskLabel: 'Risk',
    reactions: [
      { title: 'Panic buy', body: 'Hardware at peak prices. Budget torched, architecture unchanged.', risk: 'Overpay' },
      { title: 'Wait & hope', body: 'Extend support, kick the can down the road. No real strategy.', risk: 'Standstill' },
      { title: 'Cloud exodus', body: 'Uncontrolled lift-and-shift. Inefficiencies move straight into OpEx, one for one.', risk: 'Lock-in' },
    ],
    quoteText: "The forced break from buying hardware isn't lost time — it's a rare shot at getting your IT strategy in shape with no clock ticking.",
    quoteFootPre: 'Wait time',
    quoteFootPost: 'Planning time',
    schlussEyebrow: 'The strategic takeaway',
    schlussTitle: 'Get leaner before you buy',
    steps: [
      { kicker: 'Modernize the software', body: "Cloud-native, Kubernetes — workloads that don't have to scale with every hardware generation." },
      { kicker: 'Modernize the data model', body: 'An open lakehouse instead of legacy silos — decoupled from proprietary infrastructure.' },
    ],
    thesisLead: 'The target architecture comes out leaner. Freed-up hardware budget goes into modernization instead of hardware inflation. AI-ready data falls out as a by-product — not a project of its own, just the upside of clean architecture.',
    bandCockpitAlt: 'View from a derelict vehicle onto toppled server racks in the desert before the Frankfurt skyline',
    bandInteriorAlt: 'Interior of a gutted vehicle full of old hard drives and hardware scrap',
    bandKeyAlt: 'RAMmageddon — toppled server racks in a desert landscape before the Frankfurt skyline',
    stickerAlt: 'RAMmageddon — emblem as a sticker template',
    wallpapers: [
      { title: 'Key visual', preview: '/rammageddon/band-keyvisual.webp', file: '/rammageddon/downloads/rammageddon-wallpaper-keyvisual.jpg', res: '2814 × 1536', alt: 'RAMmageddon key visual: toppled server racks in the desert before the Frankfurt skyline' },
      { title: 'Frankfurt', preview: '/rammageddon/hero-wasteland-frankfurt.webp', file: '/rammageddon/downloads/rammageddon-wallpaper-frankfurt.jpg', res: '2816 × 1536', alt: 'Post-apocalyptic Frankfurt skyline under a rust-red sky' },
      { title: 'Cockpit', preview: '/rammageddon/band-cockpit.webp', file: '/rammageddon/downloads/rammageddon-wallpaper-cockpit.jpg', res: '2814 × 1536', alt: 'View from a derelict vehicle onto toppled server racks' },
      { title: 'Interior', preview: '/rammageddon/band-interior.webp', file: '/rammageddon/downloads/rammageddon-wallpaper-interieur.jpg', res: '2752 × 1536', alt: 'Interior of a gutted vehicle full of hardware scrap' },
    ],
  },
};

const c = content[lang];
const stats = c.stats;
const drivers = c.drivers;
const reactions = c.reactions;
const wallpapers = c.wallpapers;
---

<div class="wasteland">
  <!-- 1) HERO ------------------------------------------------------------- -->
  <section class="wl-hero">
    <picture class="wl-hero__media">
      <source srcset="/rammageddon/hero-wasteland-frankfurt.webp" type="image/webp" />
      <img
        src="/rammageddon/hero-wasteland-frankfurt.jpg"
        alt={c.heroAlt}
        width="2816"
        height="1536"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
    <div class="wl-hero__scrim" aria-hidden="true"></div>

    <div class="wl-hero__inner">
      <picture class="wl-badge">
        <source srcset="/rammageddon/rammageddon-badge.webp" type="image/webp" />
        <img
          src="/rammageddon/rammageddon-badge.png"
          alt={c.badgeAlt}
          width="1023"
          height="1024"
          loading="eager"
          decoding="async"
        />
      </picture>

      <p class="wl-kicker">{c.heroKicker}</p>
      <h1 class="wl-hero__line">{c.heroLine}</h1>
      <p class="wl-hero__sub">{c.heroSub}</p>
    </div>
  </section>

  <div class="wl-body">
    {lang === 'en' && t('rammageddon.langNotice') && (
      <aside class="wl-notice" role="note" aria-label="Language notice">
        <span class="wl-notice__icon" aria-hidden="true">⚠</span>
        <p class="wl-notice__text">
          {t('rammageddon.langNotice')}
          {' '}
          <a href={germanPath} class="wl-notice__link">Open the German page →</a>
        </p>
      </aside>
    )}

    <!-- 2) MARKTLAGE ------------------------------------------------------ -->
    <section class="wl-section" data-animate>
      <header class="wl-section__head">
        <p class="wl-eyebrow">{c.marktEyebrow}</p>
        <h2 class="wl-h2">{c.marktTitle}</h2>
      </header>

      <div class="wl-stats">
        {stats.map((s) => (
          <div class="wl-stat">
            <div class="wl-stat__value">{s.value}</div>
            <div class="wl-stat__label">{s.label}</div>
          </div>
        ))}
      </div>

      <div class="wl-drivers" aria-label={c.driversAria}>
        <span class="wl-drivers__tag">{c.driversLabel}</span>
        <ul class="wl-drivers__list">
          {drivers.map((d) => <li class="wl-driver">{d}</li>)}
        </ul>
      </div>
    </section>

    <!-- Atmosphäre-Band: Cockpit-POV -->
    <div class="wl-band" data-animate>
      <picture>
        <source srcset="/rammageddon/band-cockpit.webp" type="image/webp" />
        <img
          src="/rammageddon/band-cockpit.jpg"
          alt={c.bandCockpitAlt}
          width="1600"
          height="873"
          loading="lazy"
          decoding="async"
        />
      </picture>
      <span class="wl-band__scrim" aria-hidden="true"></span>
    </div>

    <!-- 3) DREI REAKTIONEN ----------------------------------------------- -->
    <section class="wl-section" data-animate>
      <header class="wl-section__head">
        <p class="wl-eyebrow">{c.reactEyebrow}</p>
        <h2 class="wl-h2">{c.reactTitle}</h2>
      </header>

      <div class="wl-cards">
        {reactions.map((r) => (
          <article class="wl-card">
            <h3 class="wl-card__title">{r.title}</h3>
            <p class="wl-card__body">{r.body}</p>
            <p class="wl-card__risk"><span class="wl-card__risk-label">{c.riskLabel}</span>{r.risk}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- Atmosphäre-Band: Wrack-Innenraum -->
    <div class="wl-band" data-animate>
      <picture>
        <source srcset="/rammageddon/band-interior.webp" type="image/webp" />
        <img
          src="/rammageddon/band-interior.jpg"
          alt={c.bandInteriorAlt}
          width="1600"
          height="893"
          loading="lazy"
          decoding="async"
        />
      </picture>
      <span class="wl-band__scrim" aria-hidden="true"></span>
    </div>

    <!-- 4) KERNBOTSCHAFT -------------------------------------------------- -->
    <section class="wl-section" data-animate>
      <blockquote class="wl-quote">
        <p class="wl-quote__text">{c.quoteText}</p>
        <footer class="wl-quote__foot">{c.quoteFootPre} <span aria-hidden="true">→</span> {c.quoteFootPost}</footer>
      </blockquote>
    </section>

    <!-- 5) STRATEGISCHE SCHLUSSFOLGERUNG --------------------------------- -->
    <section class="wl-section" data-animate>
      <header class="wl-section__head">
        <p class="wl-eyebrow">{c.schlussEyebrow}</p>
        <h2 class="wl-h2">{c.schlussTitle}</h2>
      </header>

      <div class="wl-thesis">
        <div class="wl-thesis__steps">
          {c.steps.map((step) => (
            <div class="wl-step">
              <p class="wl-step__kicker">{step.kicker}</p>
              <p class="wl-step__body">{step.body}</p>
            </div>
          ))}
        </div>
        <p class="wl-thesis__lead">{c.thesisLead}</p>
      </div>
    </section>

    <!-- Atmosphäre-Band: panoramisches Key-Visual -->
    <div class="wl-band wl-band--key" data-animate>
      <picture>
        <source srcset="/rammageddon/band-keyvisual.webp" type="image/webp" />
        <img
          src="/rammageddon/band-keyvisual.jpg"
          alt={c.bandKeyAlt}
          width="1600"
          height="873"
          loading="lazy"
          decoding="async"
        />
      </picture>
      <span class="wl-band__scrim" aria-hidden="true"></span>
    </div>

    <!-- 6) ÜBERGANG ZU DEN BRIEFINGS ------------------------------------- -->
    <section class="wl-section wl-cta" data-animate>
      <p class="wl-eyebrow">{t('rammageddon.cta.eyebrow')}</p>
      <h2 class="wl-h2">{t('rammageddon.cta.title')}</h2>
      <p class="wl-cta__body">{t('rammageddon.cta.body')}</p>
      <a href={briefingBase} class="wl-btn">
        {t('rammageddon.cta.button')}
        <span aria-hidden="true">→</span>
      </a>
    </section>

    <!-- 7) FÜR FANS — DOWNLOADS ------------------------------------------ -->
    <section class="wl-section" data-animate>
      <header class="wl-section__head">
        <p class="wl-eyebrow">{t('rammageddon.downloads.eyebrow')}</p>
        <h2 class="wl-h2">{t('rammageddon.downloads.title')}</h2>
        <p class="wl-dl__intro">{t('rammageddon.downloads.intro')}</p>
      </header>

      <h3 class="wl-dl__subhead">{t('rammageddon.downloads.wallpapers')}</h3>
      <div class="wl-dl__grid">
        {wallpapers.map((w) => (
          <figure class="wl-dl-card">
            <span class="wl-dl-card__thumb">
              <img src={w.preview} alt={w.alt} loading="lazy" decoding="async" />
            </span>
            <figcaption class="wl-dl-card__meta">
              <span class="wl-dl-card__title">{w.title}</span>
              <span class="wl-dl-card__res">{w.res}</span>
            </figcaption>
            <a
              class="wl-dl-card__btn"
              href={w.file}
              download
              aria-label={`${t('rammageddon.downloads.download')} — ${w.title} (${w.res})`}
            >
              <svg class="wl-dl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v12m0 0l-4-4m4 4l4-4M4 21h16" />
              </svg>
              {t('rammageddon.downloads.download')}
            </a>
          </figure>
        ))}
      </div>

      <h3 class="wl-dl__subhead wl-dl__subhead--sticker">{t('rammageddon.downloads.stickers')}</h3>
      <div class="wl-sticker">
        <span class="wl-sticker__art">
          <picture>
            <source srcset="/rammageddon/rammageddon-badge.webp" type="image/webp" />
            <img
              src="/rammageddon/rammageddon-badge.png"
              alt={c.stickerAlt}
              width="1023"
              height="1024"
              loading="lazy"
              decoding="async"
            />
          </picture>
        </span>
        <div class="wl-sticker__body">
          <p class="wl-sticker__note">{t('rammageddon.downloads.sticker.note')}</p>
          <div class="wl-sticker__actions">
            <a class="wl-dl-card__btn" href="/rammageddon/downloads/rammageddon-logo-sticker.png" download>
              <svg class="wl-dl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v12m0 0l-4-4m4 4l4-4M4 21h16" />
              </svg>
              {t('rammageddon.downloads.sticker.badge')}
            </a>
            <a class="wl-btn wl-btn--sm" href={stickerMuleUrl} target="_blank" rel="noopener noreferrer">
              {t('rammageddon.downloads.sticker.cta')}
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>

<style>
  /* ===================================================================
     Wasteland-Palette — strikt auf .wasteland gescopt.
     Astro scopt diese Styles zusätzlich auf die Komponente; der Rest
     der Seite (Navigation, Footer, ruhige Werkstatt-Tonalität) bleibt
     unberührt.
     =================================================================== */
  .wasteland {
    --wl-bg: #0a0907;
    --wl-bg-2: #14110d;
    --wl-panel: rgba(28, 22, 16, 0.72);
    --wl-ink: #f1e7d2;
    --wl-ink-dim: rgba(241, 231, 210, 0.72);
    --wl-ink-faint: rgba(241, 231, 210, 0.5);
    --wl-rust: #9a3a1e;
    --wl-copper: #c4753a;
    --wl-marigold: #e8a23d;
    --wl-steel: #9a958a;
    --wl-line: rgba(196, 117, 58, 0.28);

    /* Dezente Grunge-/Used-Textur (fractalNoise), kupferfarben getönt. */
    --wl-grain: url("data:image/svg+xml,%3Csvg viewBox='0 0 240 240' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3CfeColorMatrix values='0 0 0 0 0.62 0 0 0 0 0.36 0 0 0 0 0.18 0 0 0 0.06 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");

    position: relative;
    background-color: var(--wl-bg);
    background-image:
      var(--wl-grain),
      radial-gradient(ellipse 1100px 700px at 50% -5%, rgba(232, 162, 61, 0.14), transparent 70%),
      radial-gradient(ellipse 900px 600px at 50% 105%, rgba(154, 58, 30, 0.14), transparent 72%);
    color: var(--wl-ink);
  }

  /* Industrielle, kräftige Anmutung ohne zusätzliche Web-Fonts:
     schwere, hochgestellte Sans aus dem vorhandenen Stack. */
  .wasteland :global(h1),
  .wasteland :global(h2),
  .wasteland :global(h3) {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    letter-spacing: -0.01em;
  }

  /* ---------- HERO ---------- */
  .wl-hero {
    position: relative;
    min-height: clamp(34rem, 88vh, 48rem);
    display: flex;
    flex-direction: column;
    /* Platz für die fixierte Navigation reservieren, damit der Inhalt
       (Badge/Headline) nie unter die Navbar rutscht. */
    padding-top: clamp(6.5rem, 13vh, 8.5rem);
    overflow: hidden;
  }
  .wl-hero__media,
  .wl-hero__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .wl-hero__media img {
    object-fit: cover;
    object-position: center 35%;
    filter: saturate(0.92) contrast(1.05);
  }
  .wl-hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(10, 9, 7, 0.55) 0%, rgba(10, 9, 7, 0.2) 35%, rgba(10, 9, 7, 0.82) 88%, var(--wl-bg) 100%),
      linear-gradient(90deg, rgba(10, 9, 7, 0.6) 0%, transparent 55%);
  }
  .wl-hero__inner {
    position: relative;
    width: 100%;
    max-width: 72rem;
    /* margin-top:auto -> bottom-aligned wenn Platz da ist, sonst sauber
       am oberen (navbar-freien) Rand statt Overflow nach oben. */
    margin: auto auto 0;
    padding: 0 1.25rem 3.5rem;
  }
  .wl-badge {
    display: block;
    width: clamp(84px, 16vw, 140px);
    margin-bottom: 1.4rem;
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.6));
  }
  .wl-badge img {
    display: block;
    width: 100%;
    height: auto;
  }
  .wl-kicker {
    font-family: 'Inter', system-ui, sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.34em;
    font-weight: 700;
    font-size: 0.72rem;
    color: var(--wl-marigold);
    margin-bottom: 1.1rem;
  }
  .wl-hero__line {
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1.02;
    font-size: clamp(1.9rem, 6vw, 4.25rem);
    max-width: 18ch;
    color: var(--wl-ink);
    text-shadow: 0 2px 0 rgba(0, 0, 0, 0.55), 0 0 26px rgba(0, 0, 0, 0.5);
    text-wrap: balance;
  }
  .wl-hero__sub {
    margin-top: 1.4rem;
    font-size: clamp(1rem, 2.2vw, 1.4rem);
    font-weight: 600;
    color: var(--wl-copper);
    letter-spacing: 0.01em;
  }

  /* ---------- BODY / SECTIONS ---------- */
  .wl-body {
    position: relative;
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.25rem 6rem;
  }
  .wl-section {
    padding: clamp(3rem, 7vw, 5.5rem) 0;
    border-top: 1px solid var(--wl-line);
  }
  .wl-section:first-of-type {
    border-top: 0;
  }
  .wl-section__head {
    margin-bottom: 2.75rem;
  }
  .wl-eyebrow {
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-weight: 700;
    font-size: 0.7rem;
    color: var(--wl-marigold);
    margin-bottom: 0.9rem;
  }
  .wl-h2 {
    font-weight: 900;
    text-transform: uppercase;
    font-size: clamp(1.6rem, 4vw, 2.85rem);
    line-height: 1.05;
    color: var(--wl-ink);
  }

  /* ---------- FULL-BLEED ATMOSPHÄRE-BÄNDER ---------- */
  .wl-band {
    position: relative;
    left: 50%;
    width: 100vw;
    margin-left: -50vw;
    margin-block: clamp(0.5rem, 3vw, 2rem);
    height: clamp(14rem, 42vh, 23rem);
    overflow: hidden;
  }
  .wl-band--key {
    height: clamp(17rem, 54vh, 29rem);
  }
  .wl-band picture,
  .wl-band img {
    position: absolute;
