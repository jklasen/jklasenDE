---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="home" class="relative min-h-screen flex items-center overflow-hidden pt-28 pb-20">
  <!-- Background runic atmosphere -->
  <div class="absolute inset-0 -z-0">
    <div class="absolute inset-0 bg-gradient-to-b from-forge-950 via-forge-900 to-forge-950"></div>
    <!-- ember glow -->
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[900px] h-[900px] bg-blood-700/15 rounded-full blur-[140px] ember-pulse"></div>
    <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-ember-500/8 rounded-full blur-[120px]"></div>
    <!-- subtle vertical streaks -->
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(90deg, transparent 0, transparent 80px, rgba(220,209,173,1) 80px, rgba(220,209,173,1) 81px);"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      <!-- Text Content -->
      <div class="lg:col-span-7 space-y-8">
        <div class="space-y-6">
          <p class="eyebrow">
            <span>{lang === 'de' ? 'Willkommen' : 'Welcome'}</span>
          </p>

          <h1 class="leading-[0.9] tracking-tight">
            <span class="block text-2xl sm:text-3xl text-bone-200/80 mb-2" style="font-family: 'MedievalSharp', 'Cinzel', Georgia, serif;">
              {lang === 'de' ? 'Ich bin der' : "I'm"}
            </span>
            <span class="block heading-brutal uppercase text-7xl sm:text-8xl lg:text-9xl xl:text-[11rem]">JENS</span>
            <span class="block heading-brutal uppercase text-7xl sm:text-8xl lg:text-9xl xl:text-[11rem]">KLASEN</span>
          </h1>

          <div class="flex items-center gap-4 pt-2">
            <span class="block h-px w-12 bg-blood-500"></span>
            <p class="text-sm sm:text-base uppercase tracking-[0.25em] text-blood-400" style="font-family: 'MedievalSharp', 'Cinzel', Georgia, serif;">
              {t('hero.title')} · {lang === 'de' ? 'Freidenker' : 'Free Thinker'}
            </p>
          </div>
        </div>

        <p class="text-lg text-bone-200/80 leading-relaxed max-w-xl">
          {t('hero.description')}
        </p>

        <div class="flex flex-wrap gap-4 pt-2">
          <a href="#contact" class="btn-primary">
            {lang === 'de' ? 'Lass uns reden' : "Let's talk"}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="#about" class="btn-secondary">
            {lang === 'de' ? 'Die Saga lesen' : 'Read the Saga'}
          </a>
        </div>

        <!-- Quick Stats -->
        <div class="grid grid-cols-3 gap-6 pt-8 max-w-lg">
          <div class="border-l-2 border-blood-500 pl-4">
            <p class="font-display text-3xl font-black text-bone-100">25+</p>
            <p class="text-[10px] uppercase tracking-[0.2em] text-bone-300/70 mt-1">{lang === 'de' ? 'Jahre im Feld' : 'Years in the field'}</p>
          </div>
          <div class="border-l-2 border-blood-500 pl-4">
            <p class="font-display text-3xl font-black text-bone-100">30+</p>
            <p class="text-[10px] uppercase tracking-[0.2em] text-bone-300/70 mt-1">{lang === 'de' ? 'Zertifizierungen' : 'Certifications'}</p>
          </div>
          <div class="border-l-2 border-blood-500 pl-4">
            <p class="font-display text-3xl font-black text-bone-100">10×</p>
            <p class="text-[10px] uppercase tracking-[0.2em] text-bone-300/70 mt-1">vExpert</p>
          </div>
        </div>
      </div>

      <!-- Sigil / Logo -->
      <div class="lg:col-span-5 relative">
        <div class="relative w-full max-w-md mx-auto aspect-square">
          <!-- Outer rotating runic ring -->
          <div class="absolute inset-0 rune-spin pointer-events-none">
            <svg viewBox="0 0 400 400" class="w-full h-full opacity-30">
              <defs>
                <path id="runeCircle" d="M 200,200 m -190,0 a 190,190 0 1,1 380,0 a 190,190 0 1,1 -380,0" />
              </defs>
              <circle cx="200" cy="200" r="190" fill="none" stroke="rgba(220,209,173,0.4)" stroke-width="1"/>
              <circle cx="200" cy="200" r="170" fill="none" stroke="rgba(220,209,173,0.2)" stroke-width="1"/>
              <text font-family="MedievalSharp, serif" font-size="22" fill="rgba(220,209,173,0.7)" letter-spacing="6">
                <textPath href="#runeCircle" startOffset="0">
                  ᚠ ᚢ ᚦ ᚨ ᚱ ᚲ ᚷ ᚹ ᚺ ᚾ ᛁ ᛃ ᛇ ᛈ ᛉ ᛊ ᛏ ᛒ ᛖ ᛗ ᛚ ᛜ ᛞ ᛟ ᚠ ᚢ ᚦ ᚨ ᚱ
                </textPath>
              </text>
            </svg>
          </div>
          <!-- Inner counter-rotating ring -->
          <div class="absolute inset-8 rune-spin-reverse pointer-events-none">
            <svg viewBox="0 0 400 400" class="w-full h-full opacity-20">
              <circle cx="200" cy="200" r="180" fill="none" stroke="rgba(139,0,0,0.5)" stroke-width="1" stroke-dasharray="2 8"/>
            </svg>
          </div>
          <!-- Logo center — etched, no sticker -->
          <div class="absolute inset-10 flex items-center justify-center">
            <img
              src="/images/jens-transparent-dark-bg.png"
              alt="Jens Klasen Sigil"
              class="w-full h-full object-contain"
              style="filter: drop-shadow(0 0 24px rgba(139, 0, 0, 0.35)) drop-shadow(0 0 40px rgba(220, 209, 173, 0.12));"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 text-bone-300/60">
    <span class="text-[10px] uppercase tracking-[0.4em] font-display">Skol</span>
    <div class="w-px h-12 bg-gradient-to-b from-bone-300/60 to-transparent"></div>
  </div>
</section>
