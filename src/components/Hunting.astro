---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const pillars = lang === 'de'
  ? ['Hege & Pflege', 'Artenschutz', 'Tradition', 'Naturverbundenheit']
  : ['Conservation', 'Species Protection', 'Tradition', 'Nature Bond'];
---

<section class="section-padding">
  <div class="container-narrow">
    <div class="grid lg:grid-cols-2 gap-12 items-center" data-animate>
      <!-- Image -->
      <div class="relative group">
        <div class="absolute -inset-3 border border-bone-300/20 -z-0"></div>
        <div class="relative overflow-hidden">
          <img
            src="/images/IMG_0629.jpeg"
            alt={lang === 'de' ? 'Jagd und Naturschutz' : 'Hunting and Conservation'}
            class="w-full h-80 lg:h-[28rem] object-cover grayscale-[30%] group-hover:grayscale-0 transition-all duration-700"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-forge-950 via-forge-950/30 to-transparent"></div>
          <div class="absolute bottom-6 left-6 font-rune text-5xl text-blood-400">ᚦ</div>
        </div>
      </div>

      <!-- Content -->
      <div class="space-y-6">
        <p class="eyebrow">
          <span>{lang === 'de' ? 'Wild & Verantwortung' : 'Game & Responsibility'}</span>
        </p>
        <h2 class="heading-carved text-4xl sm:text-5xl">
          {t('hunting.title')}
        </h2>
        <p class="font-display uppercase tracking-[0.2em] text-sm text-blood-400">
          {t('hunting.subtitle')}
        </p>
        <p class="text-bone-200/80 leading-relaxed">
          {t('hunting.desc')}
        </p>
        <div class="grid grid-cols-2 gap-3 pt-2">
          {pillars.map((p) => (
            <div class="border border-bone-300/20 px-4 py-3 hover:border-blood-500/40 transition-colors">
              <p class="text-xs font-display uppercase tracking-[0.2em] text-bone-200">{p}</p>
            </div>
          ))}
        </div>
        <a
          href="https://www.kitzrettungrheinhessen.de/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary inline-flex mt-4"
        >
          Kitzrettung Rheinhessen
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
